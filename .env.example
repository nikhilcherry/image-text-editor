# Image Text Editor — environment template
# Copy this file to ".env" and fill in your own values.
#   cp .env.example .env
#
# The real .env is gitignored and must NEVER be committed.

# Groq API key — powers vision-based font ID + OCR (Step "Estimate Font").
# Get one free at https://console.groq.com/keys
# If left blank, the tool still works but skips Groq font/OCR detection
# and falls back to local OpenCV heuristics only.
GROQ_API_KEY=

# Groq vision model used for font identification + OCR.
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Gemini API key — powers word-level OCR with bounding boxes for the
# "find a word & replace it" tool (replace_word.py). Gemini locates the exact
# word so you never enter coordinates by hand.
# Get one free at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
